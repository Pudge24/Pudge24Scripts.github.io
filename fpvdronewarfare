            PlayerFrame.Parent = PlayersPanel
            
            local FrameCorner = Instance.new("UICorner")
            FrameCorner.CornerRadius = UDim.new(0, 6)
            FrameCorner.Parent = PlayerFrame
            
            -- Аватар (цветной круг с буквой)
