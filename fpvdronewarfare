            AvatarLabel.Size = UDim2.new(0, 40, 0, 40)
            AvatarLabel.Position = UDim2.new(0, 10, 0.5, -20)
            AvatarLabel.BackgroundColor3 = Color3.fromHSV(player.UserId % 100 / 100, 0.7, 0.7)
            AvatarLabel.Text = string.sub(player.Name, 1, 2):upper()
            AvatarLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            AvatarLabel.TextSize = 16
            AvatarLabel.Font = Enum.Font.GothamBold
            AvatarLabel.Parent = PlayerFrame
            
            local AvatarCorner = Instance.new("UICorner")
            AvatarCorner.CornerRadius = UDim.new(1, 0)
            AvatarCorner.Parent = AvatarLabel
            
            -- Имя игрока
            local NameLabel = Instance.new("TextLabel")
            NameLabel.Size = UDim2.new(1, -140, 0, 20)
            NameLabel.Position = UDim2.new(0, 60, 0.3, -10)
            NameLabel.BackgroundTransparency = 1
            NameLabel.Text = player.Name
            NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            NameLabel.TextXAlignment = Enum.TextXAlignment.Left
            NameLabel.Font = Enum.Font.GothamBold
            NameLabel.TextSize = 14
            NameLabel.Parent = PlayerFrame
            
            -- Статус (здоровье)
            local HealthLabel = Instance.new("TextLabel")
            HealthLabel.Size = UDim2.new(1, -140, 0, 20)
            HealthLabel.Position = UDim2.new(0, 60, 0.6, -10)
            HealthLabel.BackgroundTransparency = 1
            HealthLabel.Text = "❤️ HP: ?"
            HealthLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            HealthLabel.TextXAlignment = Enum.TextXAlignment.Left
            HealthLabel.Font = Enum.Font.Gotham
            HealthLabel.TextSize = 12
            HealthLabel.Parent = PlayerFrame
            
            -- Кнопка выбора
            local SelectButton = Instance.new("TextButton")
            SelectButton.Size = UDim2.new(0, 70, 0, 40)
            SelectButton.Position = UDim2.new(1, -80, 0.5, -20)
            SelectButton.BackgroundColor3 = Color3.fromRGB(70, 130, 200)
            SelectButton.Text = "ВЫБРАТЬ"
            SelectButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            SelectButton.TextSize = 11
            SelectButton.Font = Enum.Font.GothamBold
            SelectButton.Parent = PlayerFrame
            
            local ButtonCorner = Instance.new("UICorner")
            ButtonCorner.CornerRadius = UDim.new(0, 4)
            ButtonCorner.Parent = SelectButton
            
            -- Обновление здоровья в реальном времени
            coroutine.wrap(function()
                while PlayerFrame and player.Parent do
                    local char = player.Character
                    
                    -- Проверяем жив ли игрок
                    if char and char:FindFirstChild("Humanoid") then
                        local humanoid = char.Humanoid
                        local health = math.floor(humanoid.Health)
                        local maxHealth = humanoid.MaxHealth
                        
                        -- Проверяем на отрицательное здоровье или смерть
                        if health <= 0 or humanoid:GetState() == Enum.HumanoidStateType.Dead then
                            HealthLabel.Text = "✖️ 0 HP (убит)"
                            HealthLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
                        else
                            local percent = (health / maxHealth) * 100
                            
                            HealthLabel.Text = string.format("❤️ HP: %d (%.0f%%)", health, percent)
                            
                            if percent < 30 then
                                HealthLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                            elseif percent < 70 then
                                HealthLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
                            else
                                HealthLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                            end
                        end
                    else
                        -- Если персонажа нет - он мертв
                        HealthLabel.Text = "✖️ 0 HP (убит)"
                        HealthLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
                    end
                    wait(0.5)
                end
            end)()
            
            -- Эффекты наведения на кнопку
            SelectButton.MouseEnter:Connect(function()
                SelectButton.BackgroundColor3 = Color3.fromRGB(100, 150, 250)
            end)
            
            SelectButton.MouseLeave:Connect(function()
                if selectedPlayer == player then
                    SelectButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
                else
                    SelectButton.BackgroundColor3 = Color3.fromRGB(70, 130, 200)
                end
            end)
            
            -- Клик по кнопке выбора
            SelectButton.MouseButton1Click:Connect(function()
                selectedPlayer = player
                SelectedInfoLabel.Text = "🎯 Цель: " .. player.Name
                
                -- Подсвечиваем выбранного игрока
                for _, frame in pairs(PlayersPanel:GetChildren()) do
                    if frame:IsA("Frame") then
                        local btn = frame:FindFirstChild("SelectButton")
                        if btn then
                            if frame.Name == player.Name then
                                frame.BackgroundColor3 = Color3.fromRGB(50, 80, 120)
                                btn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
                                btn.Text = "ВЫБРАН"
                            else
                                frame.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
                                btn.BackgroundColor3 = Color3.fromRGB(70, 130, 200)
                                btn.Text = "ВЫБРАТЬ"
                            end
                        end
                    end
                end
            end)
            
            yOffset = yOffset + 65
        end
    end
    
    -- Если нет других игроков
    if playerCount == 0 then
        local NoPlayersLabel = Instance.new("TextLabel")
        NoPlayersLabel.Size = UDim2.new(1, -20, 0, 50)
        NoPlayersLabel.Position = UDim2.new(0, 10, 0, 10)
