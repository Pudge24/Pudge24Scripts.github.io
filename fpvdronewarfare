            PlayerFrame.Size = UDim2.new(1, -10, 0, 60)
            PlayerFrame.Position = UDim2.new(0, 5, 0, yOffset)
            PlayerFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
