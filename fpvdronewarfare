-- Функция для поиска дрона
local function findDrone()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    -- Ищем в руках
    if character then
        local toolInHand = character:FindFirstChild("FPV Drone")
        if toolInHand and toolInHand:IsA("Tool") then
            return toolInHand
        end
    end
    
    -- Ищем в рюкзаке
    if backpack then
        local toolInBackpack = backpack:FindFirstChild("FPV Drone")
        if toolInBackpack and toolInBackpack:IsA("Tool") then
            return toolInBackpack
        end
    end
    
    return nil
end

-- Функция для получения текущего дрона (модели)
local function getCurrentDroneModel()
    local droneItem = findDrone()
    if not droneItem or not droneItem:FindFirstChild("CURRENTDRONE") then
        return nil
    end
    
    local success, value = pcall(function()
        return droneItem.CURRENTDRONE.Value
    end)
    
    return success and value or nil
end

-- Функция телепортации дрона
local function teleportDroneToSelectedPlayer()
    if not selectedPlayer then
        SelectedInfoLabel.Text = "❌ Сначала выберите игрока!"
        return false
    end
    
    if selectedPlayer == LocalPlayer then
        SelectedInfoLabel.Text = "❌ Нельзя телепортироваться к себе!"
        return false
    end
    
    local drone = getCurrentDroneModel()
    if not drone then
        SelectedInfoLabel.Text = "❌ Дрон не найден (заспавньте дрон)"
        return false
    end
    
    local targetChar = selectedPlayer.Character
    if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then
        SelectedInfoLabel.Text = "❌ Игрок не имеет персонажа"
        return false
    end
    
    local targetPosition = targetChar.HumanoidRootPart.Position
    local dronePrimaryPart = drone.PrimaryPart
    
    if not dronePrimaryPart then
        SelectedInfoLabel.Text = "❌ Дрон поврежден"
        return false
    end
    
    -- Эффект телепортации
    SelectedInfoLabel.Text = "✨ Телепортация к " .. selectedPlayer.Name .. "..."
    
    -- Телепортируем дрон
    drone:SetPrimaryPartCFrame(CFrame.new(targetPosition + Vector3.new(0, 5, 0)))
    
    -- Обновляем FlightVelocity если есть
    local flightVelocity = dronePrimaryPart:FindFirstChild("FlightVelocity")
    if flightVelocity then
        pcall(function()
            flightVelocity.Velocity = Vector3.new(0, 0, 0)
        end)
    end
    
    SelectedInfoLabel.Text = "✅ Дрон у " .. selectedPlayer.Name
    
    -- Визуальный эффект (мигание)
    coroutine.wrap(function()
        for i = 1, 3 do
            dronePrimaryPart.Transparency = 0.5
            wait(0.1)
            dronePrimaryPart.Transparency = 0
            wait(0.1)
        end
    end)()
    
    return true
end

